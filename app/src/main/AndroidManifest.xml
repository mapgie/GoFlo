<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!--
        USE_EXACT_ALARM is a restricted permission for timer/alarm apps and would be rejected by
        Google Play for a period tracker. SCHEDULE_EXACT_ALARM is the correct permission here;
        the app checks canScheduleExactAlarms() at runtime and degrades gracefully.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!--
        Required for GoFlo to appear in Settings > Apps > Special app access > Do Not Disturb.
        Without this declaration the system never lists the app, so users cannot grant the policy
        access that lets custom alarms bypass DND.
    -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:name=".GoFloApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GoFlo">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <!--
                The LAUNCHER intent-filter lives on the themed aliases below, not here.
                MainActivity must still be exported so the aliases can target it and so
                notification/widget PendingIntents can reach it directly.
            -->
        </activity>

        <!--
            ── Launcher icon aliases ─────────────────────────────────────────────
            Each alias points to MainActivity and carries its own icon.
            AppIconManager.applyIcon() ensures exactly one alias is enabled at a
            time.  The default alias (original GoFlo icon) is enabled on fresh
            installs; all others start disabled.
        -->
        <activity-alias
            android:name=".MainActivityDefault"
            android:enabled="true"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityLeaf"
            android:enabled="false"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_leaf"
            android:roundIcon="@mipmap/ic_launcher_round_leaf">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityMoon"
            android:enabled="false"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_moon"
            android:roundIcon="@mipmap/ic_launcher_round_moon">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityStar"
            android:enabled="false"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_star"
            android:roundIcon="@mipmap/ic_launcher_round_star">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!--
            AlarmActivity is launched via a full-screen intent when delivery mode is ALARM.
            It shows a disruptive lock-screen-visible alarm UI with the user's custom label.
        -->
        <activity
            android:name=".notifications.AlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true" />

        <!--
            ReminderReceiver handles alarm-fired notifications only. It does NOT need
            to be exported — AlarmManager delivers via explicit component PendingIntents
            without requiring the receiver to be exported. Keeping it unexported prevents
            any other app from triggering fake notifications.
        -->
        <receiver
            android:name=".notifications.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mapgie.goflo.ACTION_PREPERIOD_REMINDER" />
                <action android:name="com.mapgie.goflo.ACTION_OVULATION_REMINDER" />
                <action android:name="com.mapgie.goflo.ACTION_DAILY_PERIOD_REMINDER" />
                <action android:name="com.mapgie.goflo.ACTION_CUSTOM_ALARM" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".notifications.AlarmActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mapgie.goflo.ACTION_CUSTOM_LOG" />
                <action android:name="com.mapgie.goflo.ACTION_CUSTOM_SNOOZE" />
            </intent-filter>
        </receiver>

        <!--
            BootReceiver is a separate, minimal receiver that handles only BOOT_COMPLETED.
            Splitting it from ReminderReceiver ensures the alarm-notification receiver can
            remain unexported while boot rescheduling still works.
        -->
        <receiver
            android:name=".notifications.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
            GoFlo home-screen widget (2×1 cells).
            Must be exported so the launcher can send APPWIDGET_UPDATE broadcasts.
        -->
        <receiver
            android:name=".widget.GoFloWidget"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!--
            GoFlo Quick Log widget (2×2 cells).
            Displays up to four active tracking categories; tapping one opens the
            app's per-day log screen for that category.
        -->
        <receiver
            android:name=".widget.QuickLogWidget"
            android:exported="true"
            android:label="GoFlo Quick Log">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_log_widget_info" />
        </receiver>

        <!--
            FileProvider for data export. Exposes files from cacheDir/exports/ via a
            content:// URI so the share sheet can deliver the export file to any target
            app without granting broad storage permissions.
            android:exported="false" is required — grantUriPermissions handles access.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
