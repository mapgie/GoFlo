<?xml version="1.0" encoding="utf-8"?>
<!--
    AppWidgetProviderInfo for the GoFlo Quick Log widget.
    - 2×2 cell minimum — gives enough room for the 2×2 category button grid.
    - updatePeriodMillis = 1 800 000 ms (30 min, the OS minimum).
      The widget is also refreshed whenever GoFloWidget.updateAllWidgets() is called
      from QuickLogWidget.updateAllWidgets().
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_quick_log"
    android:widgetCategory="home_screen"
    android:description="@string/quick_log_widget_description" />
