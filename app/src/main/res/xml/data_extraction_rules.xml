<?xml version="1.0" encoding="utf-8"?>
<!--
    All health data and preferences are excluded from both cloud backup and device transfer.
    Users who wish to move data between devices must use an explicit in-app export (future feature).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="goflo_database" />
        <exclude domain="database" path="goflo_database-shm" />
        <exclude domain="database" path="goflo_database-wal" />
        <exclude domain="file" path="datastore/goflo_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/goflo_security.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="goflo_database" />
        <exclude domain="database" path="goflo_database-shm" />
        <exclude domain="database" path="goflo_database-wal" />
        <exclude domain="file" path="datastore/goflo_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/goflo_security.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
