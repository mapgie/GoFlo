<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        Crescent built from two circular arcs – no evenOdd tricks.

        Unrotated geometry:
          Outer circle  centre (58, 54)  r = 30
          Inner circle  centre (44, 54)  r = 22  (d = 14)
          Intersection points: a = (R²−r²+d²)/2d = 21.86
                               h = √(R²−a²) ≈ 20.54
                               I1 ≈ (36, 75)   I2 ≈ (36, 33)

        Everything rotated 30° clockwise about canvas centre (54, 54):
          I1' ≈ (49, 81)   I2' ≈ (28, 45)

        Arc 1 – outer convex edge:
          From I1' large (272°) clockwise arc of r=30  →  I2'
        Arc 2 – inner concave edge:
          From I2' small (143°) clockwise arc of r=22  →  I1'
    -->
    <path
        android:fillColor="#3F51B5"
        android:pathData="M49,81 A30,30 0 1,1 28,45 A22,22 0 0,1 49,81 Z" />
</vector>
