<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        Crescent built from two circular arcs – no evenOdd tricks.
        Colour matches the settings-screen preview: #3949AB.

        Unrotated geometry:
          Outer circle  centre (58, 54)  r = 34
          Inner circle  centre (44, 54)  r = 25  (d = 14)
          a = (R²−r²+d²)/2d = (1156−625+196)/28 = 25.96
          h = √(R²−a²) = √(1156−674) ≈ 21.95
          I1 ≈ (32, 76)   I2 ≈ (32, 32)

        Rotated 30° clockwise about canvas centre (54, 54):
          I1' ≈ (46, 84)   I2' ≈ (24, 46)

        Arc 1 – outer convex edge:
          From I1'  large (≈268°) clockwise arc  r=34  →  I2'
        Arc 2 – inner concave edge:
          From I2'  small (≈138°) clockwise arc  r=25  →  I1'
    -->
    <path
        android:fillColor="#3949AB"
        android:pathData="M46,84 A34,34 0 1,1 24,46 A25,25 0 0,1 46,84 Z" />
</vector>
