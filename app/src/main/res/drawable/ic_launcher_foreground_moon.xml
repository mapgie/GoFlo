<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        Crescent moon — adaptive-icon safe zone 18–90.

        Outer circle  centre (52, 52)  r = 28
        Bite circle   centre (62, 52)  r = 24
        d = 10

        Intersection x (from outer centre) = (d² + r1² − r2²) / 2d
          = (100 + 784 − 576) / 20 = 15.4
        Intersection y = ±√(784 − 237.2) ≈ ±23.4

        Intersection points ≈ (67, 29)  and  (67, 75)

        Outer arc  (67,29)→(67,75): large CCW  (large-arc=1, sweep=0)
           goes left around the outer circle through (24, 52)
        Bite arc   (67,75)→(67,29): small CW   (large-arc=0, sweep=1)
           cuts back through the right of the bite circle
    -->

    <!-- Crescent body — warm ivory so it pops on the deep-indigo background -->
    <path
        android:fillColor="#FFF8E1"
        android:pathData="M67,29 A28,28 0 1,0 67,75 A24,24 0 0,1 67,29 Z" />

    <!-- Top highlight sheen -->
    <path
        android:fillColor="#30FFFFFF"
        android:pathData="M67,29 A28,28 0 0,0 38,28 L50,46 Z" />

    <!-- Stars — tiny filled circles scattered beside the crescent
         drawn with the zero-length-arc trick: M cx,cy a r,r 0 1,0 0.01,0 Z -->
    <path
        android:fillColor="#FFFDE7"
        android:pathData="M29,30 a2.5,2.5 0 1,0 0.01,0 Z" />
    <path
        android:fillColor="#FFFDE7"
        android:pathData="M21,54 a1.8,1.8 0 1,0 0.01,0 Z" />
    <path
        android:fillColor="#FFFDE7"
        android:pathData="M35,74 a1.5,1.5 0 1,0 0.01,0 Z" />
    <path
        android:fillColor="#FFFDE7"
        android:pathData="M42,22 a1.2,1.2 0 1,0 0.01,0 Z" />
</vector>
