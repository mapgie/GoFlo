<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        Crescent moon using the even-odd fill rule.
        Outer circle: centre (54,54) radius 32  → top (54,22)  bottom (54,86)
        Inner circle: centre (68,54) radius 26  → top (68,28)  bottom (68,80)
        Both arcs clockwise; even-odd subtracts the overlap, leaving a left-opening crescent.
    -->
    <path
        android:fillColor="#3949AB"
        android:fillType="evenOdd"
        android:pathData="M54,22 A32,32 0 0,1 54,86 A32,32 0 0,1 54,22 Z
                          M68,28 A26,26 0 0,1 68,80 A26,26 0 0,1 68,28 Z" />
</vector>
